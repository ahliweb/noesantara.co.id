---
interface Props {
	title: string;
    description?: string;
    image?: string;
}

const { 
    title, 
    description = "PT Rumah Sehat Noesantara menghadirkan solusi pembenah tanah premium dan membuka peluang agen untuk bertumbuh bersama.",
    image = "/assets/logo-noesantara-social.jpg"
} = Astro.props;

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const siteURL = 'https://noesantara.co.id';
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const socialImageURL = new URL(image, siteURL);
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | PT Rumah Sehat Noesantara</title>
    <meta name="description" content={description}>
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | PT Rumah Sehat Noesantara`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | PT Rumah Sehat Noesantara`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <link rel="icon" href="/assets/favicon.ico" type="image/x-icon">
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <Header />
    
    <main>
        <slot />
    </main>

    <Footer />

    <script src="../scripts/main.js"></script>
</body>
</html>
