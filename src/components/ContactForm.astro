---
import { PUBLIC_CONTACT_API_URL } from 'astro:env/client';

const contactApiUrl = PUBLIC_CONTACT_API_URL;
---

<div class="contact-form-shell" data-contact-api-url={contactApiUrl}>
  <h3 class="contact-form-title">Tinggalkan Pesan</h3>
  <p class="contact-form-copy">
    Kirim kebutuhan Anda ke tim NoeSantara. Kami akan menindaklanjuti melalui WhatsApp atau email.
  </p>

  <form class="contact-form" novalidate>
    <div class="contact-form-grid">
      <div>
        <label for="contact-name">Nama Lengkap</label>
        <input id="contact-name" name="name" type="text" autocomplete="name" maxlength="120" required />
      </div>

      <div>
        <label for="contact-whatsapp">No. WhatsApp</label>
        <input
          id="contact-whatsapp"
          name="whatsapp"
          type="tel"
          inputmode="tel"
          autocomplete="tel"
          placeholder="0813xxxxxxxx"
          maxlength="24"
          required
        />
      </div>
    </div>

    <div class="contact-form-grid">
      <div>
        <label for="contact-email">Email</label>
        <input id="contact-email" name="email" type="email" autocomplete="email" maxlength="200" />
      </div>

      <div>
        <label for="contact-purpose">Keperluan</label>
        <select id="contact-purpose" name="purpose" required>
          <option value="">Pilih keperluan</option>
          <option value="Daftar Kemitraan">Daftar Kemitraan</option>
          <option value="Pembelian Produk">Pembelian Produk</option>
          <option value="Konsultasi Pertanian">Konsultasi Pertanian</option>
          <option value="Permintaan Penawaran">Permintaan Penawaran</option>
          <option value="Lainnya">Lainnya</option>
        </select>
      </div>
    </div>

    <div>
      <label for="contact-message">Pesan</label>
      <textarea
        id="contact-message"
        name="message"
        rows="5"
        maxlength="4000"
        placeholder="Ceritakan kebutuhan Anda secara singkat agar tim kami dapat menyiapkan tindak lanjut yang tepat."
        required
      ></textarea>
    </div>

    <div class="contact-form-honeypot" aria-hidden="true">
      <label for="contact-company">Perusahaan</label>
      <input id="contact-company" name="company" type="text" tabindex="-1" autocomplete="off" />
    </div>

    <label class="contact-form-checkbox">
      <input id="contact-subscribe" name="subscribeToNewsletter" type="checkbox" value="yes" />
      <span>Saya bersedia menerima informasi produk dan program kemitraan melalui email.</span>
    </label>

    <div class="contact-form-actions">
      <button type="submit" class="btn btn-primary contact-form-submit">Kirim Pesan</button>
      <p class="contact-form-note">Data Anda diproses melalui endpoint server-side yang aman. Token integrasi tidak pernah dikirim ke browser.</p>
    </div>

    <p class="contact-form-status" role="status" aria-live="polite"></p>
  </form>
</div>

<script is:inline>
  (() => {
    const shell = document.currentScript?.previousElementSibling;
    if (!(shell instanceof HTMLElement)) return;

    const form = shell.querySelector('.contact-form');
    const status = shell.querySelector('.contact-form-status');
    const submitButton = shell.querySelector('.contact-form-submit');
    const apiUrl = shell.dataset.contactApiUrl;

    if (!(form instanceof HTMLFormElement) || !(status instanceof HTMLElement) || !(submitButton instanceof HTMLButtonElement) || !apiUrl) {
      return;
    }

    const setStatus = (message, tone) => {
      status.textContent = message;
      status.dataset.tone = tone;
    };

    const setSubmitting = (isSubmitting) => {
      submitButton.disabled = isSubmitting;
      submitButton.textContent = isSubmitting ? 'Mengirim...' : 'Kirim Pesan';
    };

    const validate = (payload) => {
      if (!payload.name) return 'Nama lengkap wajib diisi.';
      if (!payload.whatsapp) return 'Nomor WhatsApp wajib diisi.';
      if (!payload.purpose) return 'Silakan pilih keperluan Anda.';
      if (!payload.message) return 'Pesan wajib diisi.';

      if (payload.email) {
        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailPattern.test(payload.email)) {
          return 'Format email belum valid.';
        }
      }

      return '';
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') || '').trim(),
        whatsapp: String(formData.get('whatsapp') || '').trim(),
        email: String(formData.get('email') || '').trim(),
        purpose: String(formData.get('purpose') || '').trim(),
        message: String(formData.get('message') || '').trim(),
        honeypot: String(formData.get('company') || '').trim(),
        subscribeToNewsletter: formData.get('subscribeToNewsletter') === 'yes',
        pageUrl: window.location.href,
        source: 'website-contact-form',
      };

      const validationMessage = validate(payload);
      if (validationMessage) {
        setStatus(validationMessage, 'error');
        return;
      }

      setSubmitting(true);
      setStatus('Mengirim pesan Anda...', 'pending');

      try {
        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => ({ ok: false }));

        if (!response.ok || !result.ok) {
          throw new Error(result.error || 'Pengiriman belum berhasil. Silakan coba lagi.');
        }

        form.reset();
        setStatus('Pesan berhasil dikirim. Tim kami akan segera menghubungi Anda.', 'success');
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Terjadi gangguan saat mengirim pesan.';
        setStatus(message, 'error');
      } finally {
        setSubmitting(false);
      }
    });
  })();
</script>

<style>
  .contact-form-shell {
    background: linear-gradient(180deg, rgba(255, 255, 240, 0.98) 0%, rgba(245, 245, 220, 0.92) 100%);
    padding: 3rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(18, 53, 30, 0.08);
    box-shadow: var(--shadow-md);
  }

  .contact-form-title {
    font-family: var(--font-sans);
    margin-bottom: 0.75rem;
    color: var(--color-primary-dark);
  }

  .contact-form-copy {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .contact-form-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact-form label {
    display: block;
    margin-bottom: 0.45rem;
    font-size: 0.92rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: var(--radius-sm);
    font: inherit;
    background: rgba(255, 255, 255, 0.9);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(30, 86, 49, 0.12);
  }

  .contact-form textarea {
    resize: vertical;
    min-height: 150px;
  }

  .contact-form-checkbox {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin: 0;
  }

  .contact-form-checkbox input {
    width: 1rem;
    height: 1rem;
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  .contact-form-checkbox span {
    color: var(--color-text-light);
    font-size: 0.94rem;
  }

  .contact-form-actions {
    display: grid;
    gap: 0.75rem;
  }

  .contact-form-submit[disabled] {
    opacity: 0.75;
    cursor: wait;
  }

  .contact-form-note {
    font-size: 0.88rem;
    color: var(--color-text-light);
  }

  .contact-form-status {
    min-height: 1.5rem;
    font-weight: 600;
  }

  .contact-form-status[data-tone='pending'] {
    color: var(--color-primary);
  }

  .contact-form-status[data-tone='success'] {
    color: #1f7a3d;
  }

  .contact-form-status[data-tone='error'] {
    color: #b42318;
  }

  .contact-form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .contact-form-shell {
      padding: 2rem 1.25rem;
    }

    .contact-form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
