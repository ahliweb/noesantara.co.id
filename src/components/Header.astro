---
const currentPath = Astro.url.pathname;
---
<header class="header" id="header">
    <div class="container">
        <a href="/" class="logo">
            <img src="/assets/logo-noesantara.webp" alt="PT Rumah Sehat Noesantara Logo">
        </a>
        <div class="nav-overlay" id="navOverlay"></div>
        <nav class="nav-links" id="navLinks">
            <div class="mobile-menu-header desktop-hide">
                <a href="/" class="logo">
                    <img src="/assets/logo-noesantara.webp" alt="PT Rumah Sehat Noesantara Logo">
                </a>
                <button class="close-menu" id="closeMenuBtn"><i class="fas fa-times"></i></button>
            </div>
            <a href="/" class={currentPath === "/" ? "active" : ""}>Beranda</a>
            <a href="/perusahaan" class={currentPath.startsWith("/perusahaan") ? "active" : ""}>Perusahaan</a>
            
            <div class="nav-dropdown">
                <a href="/produk" class={currentPath.startsWith("/produk") ? "active" : ""}>Produk <i class="fas fa-chevron-down" style="font-size: 0.8em; margin-left: 5px;"></i></a>
                <div class="dropdown-content">
                    <a href="/produk/terragen">TerraGen</a>
                    <a href="/produk/phc-taburmas">PHC TaburMas</a>
                    <a href="/produk/niscardia">Niscardia</a>
                </div>
            </div>

            <a href="/kemitraan" class={currentPath.startsWith("/kemitraan") ? "active" : ""}>Kemitraan</a>
            <a href="/galeri" class={currentPath.startsWith("/galeri") ? "active" : ""}>Galeri</a>
            <a href="/testimoni" class={currentPath.startsWith("/testimoni") ? "active" : ""}>Testimoni</a>
            <a href="/artikel" class={currentPath.startsWith("/artikel") ? "active" : ""}>Artikel</a>
            <a href="/kontak" class={currentPath.startsWith("/kontak") ? "active" : ""}>Kontak</a>
            
            <a href="/kemitraan" class="btn btn-primary mobile-hide" style="margin-left: 1rem;">Daftar Mitra</a>

            <div class="mobile-menu-footer desktop-hide">
                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
                <p>info@noesantara.co.id</p>
                <a href="/kemitraan" class="btn btn-primary">Daftar Mitra</a>
            </div>
        </nav>
        <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle Menu">
            <i class="fas fa-bars"></i>
        </button>
    </div>
</header>

<style>
    /* Tambahan Dropdown Navigasi untuk header corporate */
    .nav-dropdown {
        position: relative;
        display: inline-block;
    }
    .nav-dropdown .dropdown-content {
        display: none;
        position: absolute;
        background-color: var(--color-white);
        min-width: 160px;
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        z-index: 100;
        border-radius: var(--radius-md);
        overflow: hidden;
        top: 100%;
        left: 0;
    }
    .nav-dropdown:hover .dropdown-content {
        display: block;
    }
    .nav-dropdown .dropdown-content a {
        color: var(--color-text);
        padding: 12px 16px;
        text-decoration: none;
        display: block;
        font-weight: 500;
        border-bottom: 1px solid var(--color-stone);
    }
    .nav-dropdown .dropdown-content a:hover {
        background-color: var(--color-ivory);
        color: var(--color-primary);
    }
    .nav-dropdown .dropdown-content a:last-child {
        border-bottom: none;
    }

    /* Mobile specific adjustments */
    @media (max-width: 768px) {
        .nav-dropdown .dropdown-content {
            position: static;
            box-shadow: none;
            background-color: transparent;
            padding-left: 1rem;
            display: block; /* Selalu tampilkan submenu di mobile agar mudah diklik */
        }
    }
</style>
