---
interface Props {
    standalone?: boolean;
    title?: string;
    rows?: Array<{
        no: number;
        nama: string;
        wilayah: string;
        provinsi: string;
        nohp: string;
        alamat: string;
    }>;
}

const {
    standalone = false,
    title = 'Data Mitra Agen',
    rows = []
} = Astro.props;
---

<div id={standalone ? 'data-mitra-agen' : 'modalMitra'} class={standalone ? 'mitra-page-shell' : 'modal-overlay'} style={standalone ? undefined : 'display: none;'}>
    <div class:list={["modal-content", standalone && "mitra-page-content"]} style="max-width: 900px; width: 95%;">
        {!standalone && <span class="modal-close" id="closeMitra">&times;</span>}
        <h1 style="margin-bottom: 1.5rem; color: var(--color-primary-dark); font-family: var(--font-sans); font-size: clamp(1.8rem, 3vw, 2.4rem);">{title}</h1>
        {standalone && <p style="margin: -0.5rem 0 1.5rem; color: var(--color-text-light);">Halaman ini dapat dibuka langsung melalui URL dan menampilkan data mitra agen resmi NoeSantara.</p>}
        <div class="table-responsive">
            <table class="mitra-table">
                <thead>
                    <tr>
                        <th data-sort="no" class="sortable">No <span class="sort-icon"></span></th>
                        <th data-sort="nama" class="sortable">Nama <span class="sort-icon"></span></th>
                        <th data-sort="wilayah" class="sortable">Wilayah Kab/Kota <span class="sort-icon"></span></th>
                        <th data-sort="provinsi" class="sortable">Provinsi <span class="sort-icon"></span></th>
                        <th data-sort="nohp" class="sortable">No. HP <span class="sort-icon"></span></th>
                        <th data-sort="alamat" class="sortable">Alamat <span class="sort-icon"></span></th>
                    </tr>
                    <tr class="filter-row">
                        <th><input type="text" class="column-filter" data-col="0" placeholder="Cari No"></th>
                        <th><input type="text" class="column-filter" data-col="1" placeholder="Cari Nama"></th>
                        <th><input type="text" class="column-filter" data-col="2" placeholder="Cari Wilayah"></th>
                        <th><input type="text" class="column-filter" data-col="3" placeholder="Cari Provinsi"></th>
                        <th><input type="text" class="column-filter" data-col="4" placeholder="Cari HP"></th>
                        <th><input type="text" class="column-filter" data-col="5" placeholder="Cari Alamat"></th>
                    </tr>
                </thead>
                <tbody>
                    {rows.length > 0 ? rows.map((row) => (
                        <tr>
                            <td>{row.no}</td>
                            <td>{row.nama}</td>
                            <td>{row.wilayah}</td>
                            <td>{row.provinsi}</td>
