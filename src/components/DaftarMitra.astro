        const modalMitra = document.getElementById('modalMitra');
        const btnTutup = document.getElementById('closeMitra');
        const modalHash = '#data-mitra-agen';
        
        if (btnBuka && modalMitra && btnTutup) {
            const openModal = () => {
                modalMitra.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            };

            const closeModal = () => {
                modalMitra.style.display = 'none';
                document.body.style.overflow = '';

                if (window.location.hash === modalHash) {
                    history.replaceState(null, '', window.location.pathname + window.location.search);
                }
            };

            btnBuka.addEventListener('click', (e) => {
                e.preventDefault();
                openModal();
                history.replaceState(null, '', modalHash);
            });
            
            btnTutup.addEventListener('click', closeModal);
            
            modalMitra.addEventListener('click', (e) => {
                if (e.target === modalMitra) {
                    closeModal();
                }
            });

            window.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && modalMitra.style.display === 'flex') {
                    closeModal();
                }
            });

            if (window.location.hash === modalHash) {
                openModal();
            }
        }

        // Pagination & Sorting & Filtering Logic
        const table = document.querySelector('.mitra-table');
        if (table) {
            let currentPage = 1;
            const rowsPerPage = 50;
            let currentSortCol = -1;
            let isAsc = true;
            
            const tbody = table.querySelector('tbody');
            if (!tbody) return;
            
            const originalTrs = Array.from(tbody.querySelectorAll('tr'));
            
            // Extract data for easier manipulation
            const allRows = originalTrs.map(tr => {
                const cells = Array.from(tr.querySelectorAll('td'));
                return {
                    element: tr,
                    data: cells.map(td => td.textContent ? td.textContent.trim() : '')
                };
            });
            let filteredRows = [...allRows];
            
            const renderTable = () => {
                const start = (currentPage - 1) * rowsPerPage;
                const end = start + rowsPerPage;
                const pageRows = filteredRows.slice(start, end);
                
                tbody.innerHTML = '';
                pageRows.forEach(row => tbody.appendChild(row.element));
                
                // Update pagination info
                const pageInfo = document.getElementById('pageInfo');
                const btnPrev = document.getElementById('btnPrevPage');
                const btnNext = document.getElementById('btnNextPage');
                
                if (pageInfo) {
                    const actualEnd = Math.min(end, filteredRows.length);
                    const total = filteredRows.length;
                    pageInfo.textContent = `Menampilkan ${total === 0 ? 0 : start + 1}-${actualEnd} dari ${total}`;
                }
                
                if (btnPrev instanceof HTMLButtonElement) btnPrev.disabled = currentPage === 1;
                if (btnNext instanceof HTMLButtonElement) btnNext.disabled = end >= filteredRows.length;
            };
            
            const sortHeaders = table.querySelectorAll('th.sortable');
            const filterInputs = table.querySelectorAll('.column-filter');
            
            // Sorting Logic
            sortHeaders.forEach((header, index) => {
                header.addEventListener('click', () => {
                    if (currentSortCol === index) {
                        isAsc = !isAsc;
                    } else {
                        currentSortCol = index;
                        isAsc = true;
                    }
                    
                    sortHeaders.forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
                    header.classList.add(isAsc ? 'sort-asc' : 'sort-desc');
                    
                    const multiplier = isAsc ? 1 : -1;
                    
                    filteredRows.sort((a, b) => {
                        const aText = a.data[index];
                        const bText = b.data[index];
                        
                        const aNum = parseFloat(aText);
                        const bNum = parseFloat(bText);
                        
                        if (!isNaN(aNum) && !isNaN(bNum) && aText === aNum.toString()) {
                            return (aNum - bNum) * multiplier;
                        }
                        
                        return aText.localeCompare(bText) * multiplier;
                    });
                    
                    currentPage = 1;
                    renderTable();
                });
            });
            
            // Filter Logic
            filterInputs.forEach(input => {
                input.addEventListener('input', () => {
                    const filters = Array.from(filterInputs).map(inp => {
                        if (inp instanceof HTMLInputElement) {
                            return {
                                col: parseInt(inp.dataset.col || '0'),
                                val: inp.value.toLowerCase()
                            };
                        }
                        return { col: -1, val: '' };
                    }).filter(f => f.val.length > 0);
                    
                    filteredRows = allRows.filter(row => {
                        return filters.every(f => row.data[f.col].toLowerCase().includes(f.val));
                    });
                    
                    if (currentSortCol !== -1) {
                        const multiplier = isAsc ? 1 : -1;
                        filteredRows.sort((a, b) => {
                            const aText = a.data[currentSortCol];
                            const bText = b.data[currentSortCol];
                            const aNum = parseFloat(aText);
                            const bNum = parseFloat(bText);
                            if (!isNaN(aNum) && !isNaN(bNum) && aText === aNum.toString()) {
                                return (aNum - bNum) * multiplier;
                            }
                            return aText.localeCompare(bText) * multiplier;
                        });
                    }
                    
                    currentPage = 1;
                    renderTable();
                });
            });
            
            // Pagination Listeners
            const btnPrev = document.getElementById('btnPrevPage');
            const btnNext = document.getElementById('btnNextPage');
            
            if (btnPrev) {
                btnPrev.addEventListener('click', () => {
                    if (currentPage > 1) {
                        currentPage--;
                        renderTable();
                    }
                });
            }
            if (btnNext) {
                btnNext.addEventListener('click', () => {
                    const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
                    if (currentPage < totalPages) {
                        currentPage++;
                        renderTable();
                    }
                });
            }
            
            // Initialize
            renderTable();
        }
    });
</script>
