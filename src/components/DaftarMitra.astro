<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.7);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mitra-page-shell {
        padding: 9rem 0 5rem;
        background: linear-gradient(180deg, var(--color-ivory) 0%, #ffffff 100%);
    }

    .modal-content {
        background-color: white;
        padding: 2rem;
        border-radius: var(--radius-md);
        box-shadow: 0 5px 30px rgba(0,0,0,0.3);
        position: relative;
        max-height: 90vh;
        overflow-y: auto;
    }

    .mitra-page-content {
        margin: 0 auto;
        max-height: none;
    }
    
    .modal-close {
        position: absolute;
        top: 15px;
        right: 20px;
        font-size: 28px;
        font-weight: bold;
        color: #aaa;
        cursor: pointer;
    }
    
    .modal-close:hover {
        color: var(--color-primary);
    }
    
    .table-responsive {
        overflow-x: auto;
    }
    
    .mitra-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }
    
    .mitra-table th, .mitra-table td {
        padding: 12px 15px;
        border-bottom: 1px solid #eee;
        text-align: left;
    }
    
    .mitra-table th {
        background-color: var(--color-stone);
        color: var(--color-primary-dark);
        font-weight: 600;
        position: sticky;
        top: 0;
        z-index: 10;
    }
    
    .mitra-table th.sortable {
        cursor: pointer;
        user-select: none;
        transition: background-color 0.2s;
    }
    
    .mitra-table th.sortable:hover {
        background-color: #e2e8f0;
    }
    
    .mitra-table .filter-row th {
        top: 45px;
        padding: 6px 10px;
        background-color: #f8fafc;
        cursor: default;
        z-index: 11;
        border-bottom: 2px solid #e2e8f0;
    }
    
    .column-filter {
        width: 100%;
        padding: 6px 8px;
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        font-size: 0.8rem;
        outline: none;
        transition: border-color 0.2s;
    }
    
    .column-filter:focus {
        border-color: var(--color-primary);
    }
    
    .pagination-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid #eee;
    }
    
    .pagination-buttons .btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    
    .sort-icon {
        display: inline-block;
        width: 0;
        height: 0;
        margin-left: 5px;
        vertical-align: middle;
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
        border-top: 4px solid #aaa; /* Default unsorted state */
        opacity: 0.3;
    }
    
    .sort-asc .sort-icon {
        border-bottom: 4px solid var(--color-primary-dark);
        border-top: none;
        opacity: 1;
    }
    
    .sort-desc .sort-icon {
        border-top: 4px solid var(--color-primary-dark);
        border-bottom: none;
        opacity: 1;
    }
    
    .mitra-table tbody tr:hover {
        background-color: #f9f9f9;
    }

    @media (max-width: 768px) {
        .mitra-page-shell {
            padding-top: 7rem;
        }

        .modal-content {
            padding: 1.2rem;
            width: 98% !important;
        }
        .pagination-controls {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }
        .pagination-buttons {
            width: 100%;
            display: flex;
            justify-content: space-between;
        }
        .mitra-table th, .mitra-table td {
            padding: 8px 10px;
        }
        .column-filter {
            padding: 4px 6px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
