---
import Layout from '../layouts/Layout.astro';

const photoItems = [
    {
        image: '/assets/kesehatan-tanah/produk-terragen/terragen-testimoni-cabai-1.jpeg',
        alt: 'Panen Cabai',
        title: 'Tanaman Cabai Lebat & Sehat',
        description: 'Aplikasi TerraGen kocor & spray rutin 10 hari sekali.',
        category: 'Cabai'
    },
    {
        image: '/assets/kesehatan-tanah/produk-terragen/terragen-testimoni-tomat-1.jpeg',
        alt: 'Tanaman Tomat',
        title: 'Produktivitas Tomat Meningkat',
        description: 'Bebas layu fusarium berkat kandungan Trichoderma.',
        category: 'Tomat'
    },
    {
        image: '/assets/kesehatan-tanah/produk-terragen/terragen-testimoni-pertumbuhan-bagus.jpeg',
        alt: 'Lahan Bedengan Mulsa',
        title: 'Pemulihan Lahan Bedengan',
        description: 'Tanah kembali gembur dan pH stabil setelah 2x aplikasi kocor.',
        category: 'Pemulihan Lahan'
    },
    {
        image: '/assets/kesehatan-tanah/produk-terragen/terragen-testimoni-1.jpeg',
        alt: 'Petani memegang TerraGen',
        title: 'Kepercayaan Petani Lokal',
        description: 'Edukasi langsung ke kelompok tani mitra NoeSantara.',
        category: 'Edukasi Mitra'
    },
    {
        image: '/assets/pelanggan-taburmas/pelanggan-tabur-mas-4.jpeg',
        alt: 'Testimoni PHC TaburMas',
        title: 'Hasil Panen Memuaskan',
        description: 'Buah lebih besar, lebat, dan warna cerah berkat PHC TaburMas.',
        category: 'PHC TaburMas'
    },
    {
        image: '/assets/pelanggan-taburmas/pelanggan-tabur-mas-5.jpeg',
        alt: 'Petani Sukses TaburMas',
        title: 'Aplikasi Rutin TaburMas',
        description: 'Nutrisi cepat serap yang jadi andalan petani cerdas.',
        category: 'Nutrisi Daun'
    }
];

const videoItems = [
    {
        youtubeId: '4hRapHg4ijM',
        url: 'https://www.youtube.com/watch?v=4hRapHg4ijM',
        title: 'Video Testimoni Petani',
        description: 'Dokumentasi video testimoni lapangan dari mitra NoeSantara.',
        category: 'Testimoni'
    },
    {
        youtubeId: 'O3C4wWCg5y0',
        url: 'https://www.youtube.com/watch?v=O3C4wWCg5y0',
        title: 'Video Bukti Lapangan',
        description: 'Cuplikan hasil aplikasi produk dan kondisi lahan pertanian.',
        category: 'Bukti Lapangan'
    },
    {
        youtubeId: 'Yzg7z2Bnx10',
        url: 'https://youtu.be/Yzg7z2Bnx10?si=VXx83p66IRB9tcBI',
        title: 'Testimoni dari Lebak Banten',
        description: 'Setelah 3 hari penyepraian TerraGen, pertumbuhan sangat pesat dan anakan padinya bertambah.',
        category: 'Testimoni'
    },
    {
        youtubeId: 'Yq0-mLCrrAQ',
        url: 'https://youtu.be/Yq0-mLCrrAQ?si=kwta-iQlwcvMzrP_',
        title: 'Kabar Baik dari Agen Probolinggo',
        description: 'Kabar baik lagi dari agen Probolinggo.',
        category: 'Testimoni'
    },
    {
        youtubeId: 'bv9uQNIFuzg',
        url: 'https://youtube.com/shorts/bv9uQNIFuzg?si=knVlDYjdcBkQqPil',
        title: 'Testimoni Padi dari Cilacap',
        description: 'Testimoni padi dari Kabupaten Cilacap, Jawa Tengah.',
        category: 'Testimoni'
    },
    {
        youtubeId: 'PVD4KTlOJP8',
        url: 'https://youtube.com/shorts/PVD4KTlOJP8?si=7U8lXp9uS9Hncn1D',
        title: 'Testimoni Cabe Halaman Rumah',
        description: 'Testimoni cabe halaman rumah dari Cilacap, Jawa Tengah.',
        category: 'Testimoni'
    }
];

const photoCategories = [...new Set(photoItems.map((item) => item.category))];
const videoCategories = [...new Set(videoItems.map((item) => item.category))];
---

<Layout title="Galeri & Bukti Lapangan" description="Bukti nyata efektivitas TerraGen dan PHC TaburMas di berbagai lahan pertanian Indonesia.">
    <section class="hero gallery-hero">
        <div class="container text-center">
            <h1>Bukti Lapangan</h1>
            <p>Hasil nyata penerapan produk inovasi PT Rumah Sehat Noesantara pada berbagai komoditas pertanian dan perkebunan di Indonesia.</p>
        </div>
    </section>

    <section class="bg-white pilar-section">
        <div class="container">
            <div class="text-center" style="margin-bottom: 2rem;">
                <p style="color: var(--color-text-light); font-style: italic;">Kami mendokumentasikan pemulihan tanah dan peningkatan hasil panen secara berkala dari para petani mitra kami.</p>
            </div>

            <div class="gallery-section-heading">
                <h2 class="section-title" style="margin-bottom: 0.5rem;">Galeri Foto</h2>
                <p class="section-subtitle" style="margin-bottom: 0;">Dokumentasi visual hasil aplikasi TerraGen dan PHC TaburMas di lapangan.</p>
            </div>

            <div class="gallery-category-row" data-filter-group="foto" aria-label="Kategori galeri foto">
                <button type="button" class="gallery-category-chip is-active" data-filter-button data-filter-group="foto" data-filter-value="semua">Semua</button>
                {photoCategories.map((category) => (
                    <button type="button" class="gallery-category-chip" data-filter-button data-filter-group="foto" data-filter-value={category}>{category}</button>
                ))}
            </div>

            <div class="gallery-grid gallery-photo-grid">
                {photoItems.map((item) => (
                    <button
                        type="button"
                        class="gallery-item gallery-card gallery-photo-button"
                        data-filter-item
                        data-filter-group="foto"
                        data-category={item.category}
                        data-photo-src={item.image}
                        data-photo-alt={item.alt}
                        data-photo-title={item.title}
                        aria-label={`Lihat foto ${item.title}`}
                    >
                        <img src={item.image} alt={item.alt} class="gallery-card-image">
                        <div class="gallery-card-body">
                            <span class="gallery-item-category">{item.category}</span>
                            <h4>{item.title}</h4>
                            <p>{item.description}</p>
                            <span class="photo-gallery-link">Lihat foto</span>
                        </div>
                    </button>
                ))}
            </div>

            <div class="gallery-section-heading" style="margin-top: 4rem;">
                <h2 class="section-title" style="margin-bottom: 0.5rem;">Galeri Video</h2>
                <p class="section-subtitle" style="margin-bottom: 0;">Klik video untuk menonton testimoni dan dokumentasi lapangan dalam popup.</p>
            </div>

            <div class="gallery-category-row" data-filter-group="video" aria-label="Kategori galeri video">
                <button type="button" class="gallery-category-chip is-active" data-filter-button data-filter-group="video" data-filter-value="semua">Semua</button>
                {videoCategories.map((category) => (
                    <button type="button" class="gallery-category-chip" data-filter-button data-filter-group="video" data-filter-value={category}>{category}</button>
                ))}
            </div>

            <div class="video-gallery-grid">
                {videoItems.map((video) => (
                    <button
                        type="button"
                        class="video-gallery-card video-modal-trigger"
                        data-youtube-id={video.youtubeId}
                        data-filter-item
                        data-filter-group="video"
                        data-category={video.category}
                        aria-label={`Putar ${video.title}`}
                    >
                        <div class="video-gallery-preview">
                            <img
                                src={`https://img.youtube.com/vi/${video.youtubeId}/hqdefault.jpg`}
                                alt={video.title}
                                class="video-gallery-thumbnail"
                            >
                            <span class="video-play-badge">
                                <i class="fas fa-play" aria-hidden="true"></i>
                            </span>
                        </div>
                        <div class="gallery-card-body">
                            <span class="gallery-item-category">{video.category}</span>
                            <h4>{video.title}</h4>
                            <p>{video.description}</p>
                            <span class="video-gallery-link">Tonton video</span>
                        </div>
                    </button>
                ))}
            </div>
            
            <div class="text-center" style="margin-top: 4rem;">
                <p style="font-size: 1.1rem; margin-bottom: 1.5rem;">Punya hasil panen sukses dengan produk kami? Bagikan kisah Anda!</p>
                <a href="https://wa.me/6281334629468" class="btn btn-primary" target="_blank"><i class="fab fa-whatsapp"></i> Kirim Testimoni Anda</a>
            </div>
        </div>
    </section>

    <div class="video-modal" id="videoModal" hidden>
        <div class="video-modal-backdrop" data-close-video-modal></div>
        <div class="video-modal-dialog" role="dialog" aria-modal="true" aria-label="Pemutar video YouTube">
            <button type="button" class="video-modal-close" data-close-video-modal aria-label="Tutup video">
                <i class="fas fa-times" aria-hidden="true"></i>
            </button>
            <div class="video-modal-frame-wrap">
                <iframe
                    id="videoModalFrame"
                    src="about:blank"
                    title="Video YouTube"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                ></iframe>
            </div>
        </div>
    </div>

    <div class="photo-lightbox" id="photoLightbox" hidden>
        <div class="photo-lightbox-backdrop" data-close-photo-lightbox></div>
        <div class="photo-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Pratinjau foto galeri">
            <button type="button" class="photo-lightbox-close" data-close-photo-lightbox aria-label="Tutup foto">
                <i class="fas fa-times" aria-hidden="true"></i>
            </button>
            <div class="photo-lightbox-media-wrap">
                <img id="photoLightboxImage" src="about:blank" alt="">
            </div>
            <div class="photo-lightbox-caption">
                <h3 id="photoLightboxTitle"></h3>
            </div>
        </div>
    </div>

    <script is:inline>
        (() => {
            const videoModal = document.getElementById('videoModal');
            const videoFrame = document.getElementById('videoModalFrame');
            const photoLightbox = document.getElementById('photoLightbox');
            const photoImage = document.getElementById('photoLightboxImage');
            const photoTitle = document.getElementById('photoLightboxTitle');

            if (!videoModal || !videoFrame || !photoLightbox || !photoImage || !photoTitle) return;

            const getActiveModalCount = () => [videoModal, photoLightbox].filter((modal) => !modal.hidden).length;
            const syncScrollLock = () => {
                document.body.style.overflow = getActiveModalCount() > 0 ? 'hidden' : '';
            };

            const openVideoModal = (youtubeId) => {
                videoFrame.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0`;
                videoModal.hidden = false;
                syncScrollLock();
            };

            const closeVideoModal = () => {
                videoFrame.src = 'about:blank';
                videoModal.hidden = true;
                syncScrollLock();
            };

            const openPhotoLightbox = (src, alt, title) => {
                photoImage.src = src;
                photoImage.alt = alt || title || 'Foto galeri';
                photoTitle.textContent = title || alt || 'Foto galeri';
                photoLightbox.hidden = false;
                syncScrollLock();
            };

            const closePhotoLightbox = () => {
                photoImage.src = 'about:blank';
                photoImage.alt = '';
                photoTitle.textContent = '';
                photoLightbox.hidden = true;
                syncScrollLock();
            };

            const setButtonState = (group, value) => {
                document.querySelectorAll(`[data-filter-button][data-filter-group="${group}"]`).forEach((item) => {
                    item.classList.toggle('is-active', item.dataset.filterValue === value);
                });
            };

            const animateItemVisibility = (item, shouldShow) => {
                clearTimeout(item._filterTimer);

                if (shouldShow) {
                    item.hidden = false;
                    item.classList.remove('is-hidden');
                    item.classList.add('is-entering');
                    requestAnimationFrame(() => {
                        requestAnimationFrame(() => {
                            item.classList.remove('is-filtered-out');
                        });
                    });

                    item._filterTimer = window.setTimeout(() => {
                        item.classList.remove('is-entering');
                    }, 260);
                    return;
                }

                item.classList.add('is-filtered-out');
                item._filterTimer = window.setTimeout(() => {
                    item.hidden = true;
                    item.classList.add('is-hidden');
                    item.classList.remove('is-entering');
                }, 220);
            };

            const updateUrl = (state, mode = 'replace') => {
                const url = new URL(window.location.href);
                if (state.foto && state.foto !== 'semua') {
                    url.searchParams.set('foto', state.foto);
                } else {
                    url.searchParams.delete('foto');
                }

                if (state.video && state.video !== 'semua') {
                    url.searchParams.set('video', state.video);
                } else {
                    url.searchParams.delete('video');
                }

                const nextUrl = `${url.pathname}${url.search}${url.hash}`;
                if (mode === 'push') {
                    window.history.pushState({}, '', nextUrl);
                    return;
                }

                window.history.replaceState({}, '', nextUrl);
            };

            const applyFilter = (group, value, updateHistory = true) => {
                setButtonState(group, value);

                document.querySelectorAll(`[data-filter-item][data-filter-group="${group}"]`).forEach((item) => {
                    const category = item.dataset.category;
                    const isVisible = value === 'semua' || category === value;
                    animateItemVisibility(item, isVisible);
                });

                filterState[group] = value;
                if (updateHistory) updateUrl(filterState, 'push');
            };

            const getValidInitialValue = (group, paramName) => {
                const value = new URLSearchParams(window.location.search).get(paramName);
                if (!value) return 'semua';

                const hasMatch = Array.from(document.querySelectorAll(`[data-filter-button][data-filter-group="${group}"]`)).some(
                    (button) => button.dataset.filterValue === value
                );

                return hasMatch ? value : 'semua';
            };

            const filterState = {
                foto: getValidInitialValue('foto', 'foto'),
                video: getValidInitialValue('video', 'video')
            };

            document.querySelectorAll('.video-modal-trigger').forEach((trigger) => {
                trigger.addEventListener('click', () => {
                    const youtubeId = trigger.dataset.youtubeId;
                    if (youtubeId) openVideoModal(youtubeId);
                });
            });

            document.querySelectorAll('.gallery-photo-button').forEach((trigger) => {
                trigger.addEventListener('click', () => {
                    const src = trigger.dataset.photoSrc;
                    if (!src) return;

                    openPhotoLightbox(src, trigger.dataset.photoAlt, trigger.dataset.photoTitle);
                });
            });

            document.querySelectorAll('[data-filter-button]').forEach((button) => {
                button.addEventListener('click', () => {
                    const group = button.dataset.filterGroup;
                    const value = button.dataset.filterValue;
                    if (!group || !value) return;

                    applyFilter(group, value);
                });
            });

            videoModal.querySelectorAll('[data-close-video-modal]').forEach((element) => {
                element.addEventListener('click', closeVideoModal);
            });

            photoLightbox.querySelectorAll('[data-close-photo-lightbox]').forEach((element) => {
                element.addEventListener('click', closePhotoLightbox);
            });

            document.addEventListener('keydown', (event) => {
                if (event.key !== 'Escape') return;
                if (!photoLightbox.hidden) closePhotoLightbox();
                if (!videoModal.hidden) closeVideoModal();
            });

            window.addEventListener('popstate', () => {
                applyFilter('foto', getValidInitialValue('foto', 'foto'), false);
                applyFilter('video', getValidInitialValue('video', 'video'), false);
            });

            applyFilter('foto', filterState.foto, false);
            applyFilter('video', filterState.video, false);
            updateUrl(filterState);
        })();
    </script>
</Layout>

<style>
    .gallery-section-heading {
        margin-bottom: 1rem;
    }

    .gallery-category-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 2rem;
    }

    .gallery-category-chip,
    .gallery-item-category {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.03em;
    }

    .gallery-category-chip {
        border: 1px solid transparent;
        padding: 0.65rem 1rem;
        background: rgba(140, 158, 125, 0.14);
        color: var(--color-primary-dark);
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .gallery-category-chip.is-active,
    .gallery-category-chip:hover {
        background: var(--color-primary-dark);
        color: white;
        border-color: var(--color-primary-dark);
    }

    .gallery-item-category {
        margin-bottom: 0.85rem;
        padding: 0.4rem 0.8rem;
        background: var(--color-stone);
        color: var(--color-primary-dark);
    }

    .gallery-photo-grid,
    .video-gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .gallery-card,
    .video-gallery-card {
        border: 0;
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        background: white;
        transition: opacity 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
    }

    .gallery-photo-button {
        appearance: none;
        display: block;
        padding: 0;
        cursor: pointer;
        text-align: inherit;
    }

    .gallery-card.gallery-item {
        aspect-ratio: auto;
    }

    .gallery-photo-button:focus-visible,
    .video-gallery-card:focus-visible,
    .gallery-category-chip:focus-visible,
    .video-modal-close:focus-visible,
    .photo-lightbox-close:focus-visible {
        outline: 3px solid rgba(140, 158, 125, 0.45);
        outline-offset: 2px;
    }

    .gallery-card-image,
    .video-gallery-thumbnail {
        display: block;
        width: 100%;
        height: 250px;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .gallery-card-body {
        padding: 1rem;
        background: white;
        text-align: left;
    }

    .gallery-card-body h4 {
        font-family: var(--font-sans);
        color: var(--color-primary-dark);
        margin-bottom: 0.5rem;
    }

    .gallery-card-body p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        margin-bottom: 0;
    }

    .gallery-item:hover img,
    .video-gallery-card:hover .video-gallery-thumbnail {
        transform: scale(1.05);
    }

    [data-filter-item].is-filtered-out {
        opacity: 0;
        transform: translateY(12px) scale(0.98);
        pointer-events: none;
    }

    [data-filter-item].is-entering {
        animation: gallery-item-in 0.26s ease;
    }

    [data-filter-item].is-hidden {
        display: none;
    }

    .video-gallery-card {
        appearance: none;
        display: flex;
        flex-direction: column;
        width: 100%;
        padding: 0;
        cursor: pointer;
        text-align: inherit;
    }

    .video-gallery-preview {
        position: relative;
        overflow: hidden;
        background: #000;
    }

    .video-play-badge {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.75rem;
        color: white;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.15));
    }

    .video-gallery-link {
        display: inline-flex;
        margin-top: 1rem;
        color: var(--color-primary-dark);
        font-weight: 700;
    }

    .photo-gallery-link {
        display: inline-flex;
        margin-top: 1rem;
        color: var(--color-primary-dark);
        font-weight: 700;
    }

    .video-modal[hidden] {
        display: none;
    }

    .photo-lightbox[hidden] {
        display: none;
    }

    .video-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

    .photo-lightbox {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

    .video-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.72);
    }

    .photo-lightbox-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.82);
    }

    .video-modal-dialog {
        position: relative;
        width: min(960px, 100%);
        background: #111;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }

    .photo-lightbox-dialog {
        position: relative;
        width: min(1000px, 100%);
        max-height: calc(100vh - 3rem);
        background: #111;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }

    .video-modal-close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        z-index: 1;
        width: 2.5rem;
        height: 2.5rem;
        border: 0;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.6);
        color: white;
        cursor: pointer;
    }

    .photo-lightbox-close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        z-index: 1;
        width: 2.5rem;
        height: 2.5rem;
        border: 0;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.6);
        color: white;
        cursor: pointer;
    }

    .video-modal-frame-wrap {
        position: relative;
        width: 100%;
        padding-top: 56.25%;
    }

    .video-modal-frame-wrap iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    .photo-lightbox-media-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem 1.5rem 0;
        max-height: calc(100vh - 9rem);
    }

    .photo-lightbox-media-wrap img {
        width: 100%;
        max-height: calc(100vh - 12rem);
        object-fit: contain;
        border-radius: var(--radius-md);
    }

    .photo-lightbox-caption {
        padding: 1rem 1.5rem 1.5rem;
        color: white;
    }

    .photo-lightbox-caption h3 {
        margin: 0;
        font-family: var(--font-sans);
    }

    @keyframes gallery-item-in {
        from {
            opacity: 0;
            transform: translateY(12px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .gallery-hero {
        min-height: 40vh;
        align-items: center;
        padding-top: 8rem;
        padding-bottom: 3rem;
    }

    @media (max-width: 768px) {
        .gallery-hero {
            padding-top: 6rem;
        }

        .video-modal {
            padding: 1rem;
        }

        .photo-lightbox {
            padding: 1rem;
        }

        .photo-lightbox-media-wrap {
            padding: 1rem 1rem 0;
        }

        .photo-lightbox-caption {
            padding: 1rem;
        }
    }
</style>
