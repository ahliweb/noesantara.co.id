---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hubungi Kami" description="Layanan pelanggan dan pusat informasi PT Rumah Sehat Noesantara. Kami siap membantu kebutuhan kemitraan dan produk Anda.">
    <!-- Hero Kontak -->
    <section class="hero" style="min-height: 40vh; align-items: center; padding-top: 8rem; padding-bottom: 3rem;">
        <div class="container text-center">
            <h1 style="font-size: 3rem; margin-bottom: 1rem;">Hubungi Kami</h1>
            <p style="font-size: 1.2rem; max-width: 700px; margin: 0 auto;">Punya pertanyaan seputar produk atau peluang kemitraan? Tim PT Rumah Sehat Noesantara siap melayani Anda.</p>
        </div>
    </section>

    <section class="bg-white pilar-section">
        <div class="container">
            <div style="display: flex; flex-wrap: wrap; gap: 4rem;">
                
                <!-- Info Kontak -->
                <div style="flex: 1; min-width: 300px;">
                    <h2 class="section-title" style="text-align: left; margin-bottom: 2rem;">Pusat Layanan</h2>
                    
                    <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: flex-start;">
                        <div style="width: 50px; height: 50px; background: rgba(30,81,40,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-primary); font-size: 1.2rem; flex-shrink: 0;">
                            <i class="fas fa-building"></i>
                        </div>
                        <div>
                            <h4 style="font-family: var(--font-sans); margin-bottom: 0.5rem; color: var(--color-text);">Kantor Pusat PT Rumah Sehat Noesantara</h4>
                            <p style="color: var(--color-text-light); line-height: 1.6;">Jl. Bhayangkara, Kel. Pasir Panjang, Kec. Arut Selatan,<br>Kab. Kotawaringin Barat, Kalimantan Tengah.</p>
                        </div>
                    </div>
                    
                    <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: flex-start;">
                        <div style="width: 50px; height: 50px; background: rgba(30,81,40,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-primary); font-size: 1.2rem; flex-shrink: 0;">
                            <i class="fab fa-whatsapp"></i>
                        </div>
                        <div>
                            <h4 style="font-family: var(--font-sans); margin-bottom: 0.5rem; color: var(--color-text);">WhatsApp Resmi / Layanan Kemitraan</h4>
                            <p style="color: var(--color-text-light); line-height: 1.6;">+62 813-3462-9468</p>
                            <a href="https://wa.me/6281334629468" class="text-primary" style="font-size: 0.9rem; font-weight: 600;" target="_blank">Chat Sekarang &rarr;</a>
                        </div>
                    </div>
                    
                    <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: flex-start;">
                        <div style="width: 50px; height: 50px; background: rgba(30,81,40,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-primary); font-size: 1.2rem; flex-shrink: 0;">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <h4 style="font-family: var(--font-sans); margin-bottom: 0.5rem; color: var(--color-text);">Email</h4>
                            <p style="color: var(--color-text-light); line-height: 1.6;">info@noesantara.co.id</p>
                        </div>
                    </div>
                    <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: flex-start;">
                        <div style="width: 50px; height: 50px; background: rgba(0,136,204,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #0088cc; font-size: 1.2rem; flex-shrink: 0;">
                            <i class="fab fa-telegram"></i>
                        </div>
                        <div>
                            <h4 style="font-family: var(--font-sans); margin-bottom: 0.5rem; color: var(--color-text);">Grup Komunitas Mitra</h4>
                            <p style="color: var(--color-text-light); line-height: 1.6;">Diskusi & Informasi Terkini</p>
                            <a href="https://t.me/+RqrDYxw_gLI0OWI1" class="text-primary" style="font-size: 0.9rem; font-weight: 600; color: #0088cc;" target="_blank">Gabung Telegram &rarr;</a>
                        </div>
                    </div>
                </div>

                <!-- Form / Map -->
                <div style="flex: 1.5; min-width: 300px;">
                    <div style="background: var(--color-ivory); padding: 3rem; border-radius: var(--radius-lg);">
                        <h3 style="font-family: var(--font-sans); margin-bottom: 1.5rem; color: var(--color-primary-dark);">Tinggalkan Pesan</h3>
                        <form action="#" method="POST">
                            <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
                                <div style="flex: 1;">
                                    <label for="name" style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--color-text-light);">Nama Lengkap</label>
                                    <input type="text" id="name" style="width: 100%; padding: 0.8rem; border: 1px solid var(--color-stone); border-radius: var(--radius-sm); font-family: inherit;">
                                </div>
                                <div style="flex: 1;">
                                    <label for="phone" style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--color-text-light);">No. WhatsApp</label>
                                    <input type="tel" id="phone" style="width: 100%; padding: 0.8rem; border: 1px solid var(--color-stone); border-radius: var(--radius-sm); font-family: inherit;">
                                </div>
                            </div>
                            <div style="margin-bottom: 1rem;">
                                <label for="subject" style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--color-text-light);">Keperluan</label>
                                <select id="subject" style="width: 100%; padding: 0.8rem; border: 1px solid var(--color-stone); border-radius: var(--radius-sm); font-family: inherit; background: white;">
                                    <option value="kemitraan">Daftar Kemitraan (Agen/Reseller)</option>
                                    <option value="pembelian">Pembelian Produk</option>
                                    <option value="konsultasi">Konsultasi Pertanian</option>
                                    <option value="lainnya">Lainnya</option>
                                </select>
                            </div>
                            <div style="margin-bottom: 1.5rem;">
                                <label for="message" style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--color-text-light);">Pesan</label>
                                <textarea id="message" rows="5" style="width: 100%; padding: 0.8rem; border: 1px solid var(--color-stone); border-radius: var(--radius-sm); font-family: inherit; resize: vertical;"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem; border: none; cursor: pointer;">Kirim Pesan</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
